# Database
DATABASE_URL=postgresql://recipe_user:recipe_pass@localhost:5432/recipe_app

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Cloudinary (image storage — required in production, optional in dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email sending via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# IMAP email import (optional)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
EMAIL_RECIPE_TAG=recette

# Local uploads (dev only, ignored when CLOUDINARY_CLOUD_NAME is set)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
